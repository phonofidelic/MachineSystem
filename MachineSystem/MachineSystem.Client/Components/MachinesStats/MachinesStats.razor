<div class="collapse @(IsOpen ? "collapse-open"  :"collapse-close") sm:collapse-open w-full">
    <button tabindex="-1" class="p-2 collapse-title text-left sm:pointer-events-none flex w-full justify-between" @onclick="@(() => ToggleOpen())">
        <h3 class="text-lg text-left w-full">Stats</h3>
        <div tabindex="0" title="@(IsOpen ? "Close stats" : "Open stats")" class="relative w-6 flex items-center sm:hidden swap swap-rotate @(IsOpen ? "swap-active" : "")">
            <div class="absolute swap-on rotate-180">
                <ChevronDownIcon />
            </div>
            <div class="absolute swap-off">
                <ChevronDownIcon />
            </div>
        </div>
    </button>
    <div class="collapse-content">
        <div class="stats stats-horizontal sm:stats-vertical w-full">
            <div class="stat">
                <div class="stat-title">Total Machines Count</div>
                <div class="stat-value @(Machines is null ? "skeleton" : "")">@MachinesTotalCount</div>
                <div class="stat-desc">21% more than last month</div>
            </div>
            <div class="stat">
                <div class="stat-title">Machines Online</div>
                <div class="stat-value @(Machines is null ? "skeleton" : "")">@MachinesOnlineCount</div>
                <div class="stat-desc">@MachinesOnlinePercentage %</div>
            </div>
            <div class="stat">
                <div class="stat-title">Machines Operational</div>
                <div class="stat-value @(Machines is null ? "skeleton" : "")">@MachinesOperationalCount</div>
                <div class="stat-desc">@MachinesOperationalPercentage %</div>
            </div>
        </div>
    </div>
</div>