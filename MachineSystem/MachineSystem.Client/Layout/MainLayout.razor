@inherits LayoutComponentBase

<ErrorBoundary>
    <ChildContent>
        <div class="w-full h-screen flex flex-col">
            <nav class="navbar w-full bg-base-100 shadow-sm flex w-full justify-between p-2">
                <h1 class="text-2xl">MachineSystem</h1>
                <ul class="flex gap-4">
                    <li>
                        <a class="link link-hover" href=".">One</a>
                    </li>
                    <li>
                        <a class="link link-hover" href=".">Two</a>
                    </li>
                    <li>
                        <a class="link link-hover" href=".">Three</a>
                    </li>
                </ul>
            </nav>
            <div class="p-2 flex-1 flex flex-col">
                @Body
            </div>
        </div>
    </ChildContent>
    <ErrorContent>
        <div class="hero py-6 min-h-auto">
            <div class="hero-content text-center">
                <div class="max-w-md">
                    <h4 class="text-5xl">Oops!</h4>
                    <p class="py-5">
                        An unhandled error has occurred.
                    </p>
                    <a href="." class="btn btn-primary">Reload</a>
                </div>
            </div>
        </div>
    </ErrorContent>
</ErrorBoundary>
