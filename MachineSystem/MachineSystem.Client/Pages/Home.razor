@page "/" 
@attribute [StreamRendering(true)]
@using MachineSystem.Client.Components
@using MachineSystem.Client.Components.MachineList

<PageTitle>Dashboard</PageTitle>

<header class="p-2 mb-2">
  <h2 class="text-xl">Dashboard</h2>
  <p class="text-sm text-base-content/50">Overview of connected Machines</p>
</header>
<main>
  <div class="sm:flex w-full gap-2">
    <div
      class="w-full sm:w-1/3 bg-base-100 p-2 mb-2 sm:mb-0 rounded-box shadow-sm">
      <h3 class="text-lg">Stats</h3>
    </div>
    <div class="w-full sm:w-2/3 bg-base-100 p-2 rounded-box shadow-sm">
      <MachineList />
    </div>
  </div>
</main>
