@page "/" 
@attribute [StreamRendering(true)]
@using MachineSystem.BlazorClient.Components
@using MachineSystem.BlazorClient.Components.CreateMachineForm
@using MachineSystem.BlazorClient.Components.MachineList
@using MachineSystem.BlazorClient.Components.MachinesStats

<PageTitle>Dashboard</PageTitle>

<header class="p-2 mb-2">
  <h2 class="text-xl">Dashboard</h2>
  <p class="text-sm text-base-content/50">Overview of connected Machines</p>
</header>
<main class="flex-1">
  <div class="flex flex-col sm:flex-row w-full gap-2 h-full">
    <div class="w-full sm:w-1/3 bg-base-100 p-2 sm:mb-0 rounded-box shadow-sm">
      <MachinesStats Machines="@machines" />
    </div>
    <div class="w-full h-full sm:w-2/3 bg-base-100 p-2 rounded-box shadow-sm overflow-hidden">
      <MachineList Machines="@machines" OnMachinesListUpdated="UpdateMachinesListAsync" />
    </div>
  </div>
</main>

<dialog id="my_modal_1" class="modal modal-bottom sm:modal-middle">
  <div class="modal-box">
    <form method="dialog">
      <button title="Cancel" class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2"><CloseIcon /></button>
    </form>
    <CreateMachineForm OnMachinesListUpdated="@UpdateMachinesListWithUpdaterAsync" />
  </div>
    <form method="dialog" class="modal-backdrop">
      <button class="block sm:hidden">Cancel</button>
    </form>
</dialog>
