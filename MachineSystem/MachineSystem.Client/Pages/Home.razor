@page "/" 
@attribute [StreamRendering(true)]
@using MachineSystem.BlazorClient.Components
@using MachineSystem.BlazorClient.Components.MachineList

<PageTitle>Dashboard</PageTitle>

<header class="p-2 mb-2">
  <h2 class="text-xl">Dashboard</h2>
  <p class="text-sm text-base-content/50">Overview of connected Machines</p>
</header>
<main class="flex-1">
  <div class="sm:flex w-full gap-2 h-full">
    <div
      class="w-full sm:w-1/3 bg-base-100 p-2 mb-2 sm:mb-0 rounded-box shadow-sm">
      <h3 class="text-lg">Stats</h3>
    </div>
    <div class="w-full h-full sm:w-2/3 bg-base-100 p-2 rounded-box shadow-sm overflow-hidden">
      <MachineList />
    </div>
  </div>
</main>

<dialog id="my_modal_1" class="modal">
  <div class="modal-box">
    <form method="dialog">
      <button title="Cancel" class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
    </form>
    <h3 class="text-lg">Add a new Machine</h3>
    <p class="py-4 text-base">Enter details for the new Machine</p>
      <form>
        <div class="modal-action">
          <button class="btn btn-primary">Create</button>
        </div>
      </form>
  </div>
</dialog>
